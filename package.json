{
  "name": "hashtagcms",
  "version": "3.0.0",
  "description": "Hashtag CMS, Use it as Headless CMS or Bundled, API enabled, Admin Panel, Multisite, Multi-platform, Multilingual.",
  "main": "app.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hashtagcms/hashtagcms.git"
  },
  "keywords": [
    "HashtagCMS",
    "Headless CMS",
    "CMS",
    "Mobile API Supported"
  ],
  "author": "Marghoob Suleman",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/hashtagcms/hashtagcms/issues"
  },
  "homepage": "https://github.com/hashtagcms/hashtagcms#readme",
  "scripts": {
    "dev": "webpack --mode development --watch",
    "dev:build": "webpack --mode development",
    "build": "webpack --mode production",
    "dev:fe": "cross-env MODE=fe webpack --mode development --watch",
    "dev:be": "cross-env MODE=be webpack --mode development --watch",
    "build:fe": "cross-env MODE=fe webpack --mode production",
    "build:be": "cross-env MODE=be webpack --mode production",
    "dev:kit": "cross-env MODE=both webpack --mode development && cp -r public/assets/ ../packages-testing/public/assets/hashtagcms/",
    "build:kit": "cross-env MODE=both webpack --mode production && cp -r public/assets/ ../packages-testing/public/assets/hashtagcms/"
  },
  "dependencies": {
    "@hashtagcms/admin-sdk": "^2.0.0",
    "@hashtagcms/admin-ui-kit": "^2.0.0",
    "@hashtagcms/web-sdk": "^2.0.0",
    "@hashtagcms/web-ui-kit": "^2.0.0",
    "axios": "^1.8.4",
    "bootstrap": "^5.3.3",
    "font-awesome": "^4.7.0",
    "mitt": "^3.0.1",
    "motion": "^12.36.0",
    "pluralize": "^8.0.0",
    "secure-ls": "^2.0.0",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@tailwindcss/postcss": "^4.1.18",
    "@vue/compiler-sfc": "^3.5.13",
    "autoprefixer": "^10.4.24",
    "babel-loader": "^10.0.0",
    "case-sensitive-paths-webpack-plugin": "^2.4.0",
    "copy-webpack-plugin": "^13.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "cssnano": "^7.0.6",
    "mini-css-extract-plugin": "^2.10.1",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.5",
    "tailwindcss": "^4.2.1",
    "vue-loader": "^17.4.2",
    "vue-style-loader": "^4.1.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1",
    "webpack-merge": "^6.0.1"
  }
}
